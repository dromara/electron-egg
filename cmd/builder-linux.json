{
  "productName": "ee",
  "appId": "com.electron.ee",
  "copyright": "© 2026 duola Technology Co., Ltd.",
  "directories": {
    "output": "out"
  },
  "asar": true,
  "electronLanguages": ["en-US", "zh-CN"],
  "files": [
    "public",
    "package.json",
    "node_modules/**/*"
  ],
  "extraResources": [
    {
      "from": "build/extraResources",
      "to": "extraResources"
    }
  ],
  "publish": [
    {
      "provider": "generic",
      "url": ""
    }
  ],
  "linux": {
    "icon": "build/icons/icon.icns",
    "artifactName": "${productName}-${os}-${version}-${arch}.${ext}",
    "target": [
      "deb"
    ],
    "category": "Utility"
  }
}