{
  "productName": "ee",
  "appId": "com.electron.ee",
  "copyright": "© 2026 duola Technology Co., Ltd.",
  "directories": {
    "output": "out"
  },
  "asar": true,
  "electronLanguages": ["en-US", "zh-CN"],
  "files": [
    "**/*",
    "!cmd/",
    "!data/",
    "!electron/",
    "!frontend/",
    "!logs/",
    "!out/",
    "!go/",
    "!ohos_hap/",
    "!python/",
    "!**/.claude",
    "!**/.trae",
    "!**/.vscode",
    "!CLAUDE.md"
  ],
  "extraResources": [
    {
      "from": "build/extraResources",
      "to": "extraResources"
    }
  ],
  "publish": [
    {
      "provider": "generic",
      "url": ""
    }
  ],
  "mac": {
    "icon": "build/icons/icon.icns",
    "artifactName": "${productName}-${os}-${version}-${arch}.${ext}",
    "darkModeSupport": true,
    "hardenedRuntime": false
  }
}