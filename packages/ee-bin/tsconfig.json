{
  "compilerOptions": {
    "target": "ES2020",                          // 指定编译后的 JavaScript 目标版本为 ES2020
    "module": "NodeNext",                        // 使用 Node.js 的 ESM/CJS 互操作模块系统，自动根据 package.json 的 type 字段选择模块格式
    "moduleResolution": "NodeNext",              // 使用 Node.js 的模块解析策略，支持 ESM 的严格解析规则（如必须写文件扩展名）
    "lib": ["ES2020"],                           // 编译时包含 ES2020 的内置 API 类型声明（如 Promise.allSettled、BigInt 等）
    "outDir": "./dist/esm",                      // 编译输出目录，ESM 格式代码输出到 dist/esm
    "rootDir": "./src",                          // 指定源码根目录，用于控制输出目录的结构
    "declaration": true,                         // 生成 .d.ts 类型声明文件，供其他 TypeScript 项目使用
    "declarationMap": true,                      // 生成 .d.ts.map 声明源映射，支持跳转到原始 TypeScript 源码
    "sourceMap": true,                           // 生成 .js.map 源映射文件，便于调试时映射回 TypeScript 源码
    "strict": true,                              // 启用所有严格类型检查选项，包括 strictNullChecks、noImplicitAny 等
    "esModuleInterop": true,                     // 启用 ES 模块与 CommonJS 模块的互操作性，允许用 import 导入 CJS 模块
    "allowSyntheticDefaultImports": true,        // 允许对没有默认导出的模块使用默认导入语法（如 import fs from 'fs'）
    "forceConsistentCasingInFileNames": true,    // 强制文件名大小写一致，避免因操作系统文件系统差异导致的模块解析问题
    "skipLibCheck": true,                        // 跳过所有 .d.ts 声明文件的类型检查，加快编译速度
    "resolveJsonModule": true,                   // 允许导入 .json 文件，并为其生成类型声明
    "isolatedModules": true,                     // 确保每个文件可以独立编译（Babel 等工具的要求），禁止跨文件的类型导出
    "noImplicitAny": true,                       // 禁止隐式的 any 类型，要求必须为没有类型注解的变量/参数显式指定类型
    "noImplicitReturns": true,                   // 要求函数中所有代码路径都必须有显式的 return 语句（返回 void 除外）
    "noUnusedLocals": true,                      // 报错未使用的局部变量，帮助清理死代码
    "noUnusedParameters": true,                  // 报错未使用的函数参数，保持代码整洁（可用 _ 前缀忽略）
    "exactOptionalPropertyTypes": true,          // 区分可选属性与 undefined 值，{ a?: string } 不接受 { a: undefined }
    "noUncheckedIndexedAccess": true,            // 索引访问（如 obj[key]）返回类型包含 undefined，强制做非空检查
    "types": ["node"]                            // 仅包含 node 的类型声明，排除 @types 目录下的其他全局类型
  },
  "include": ["src/**/*"],                       // 包含 src 目录下的所有文件进行编译
  "exclude": ["node_modules", "dist", "tests"]   // 排除依赖目录、编译输出目录和测试目录
}
