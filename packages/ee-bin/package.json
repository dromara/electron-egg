{
  "name": "ee-bin-ts",
  "version": "5.0.0",
  "description": "ee-bin typescript version",
  "main": "./dist/esm/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "ee-bin": "./dist/esm/index.js"
  },
  "files": [
    "dist",
    "config"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "adm-zip": "^0.4.11",
    "bytenode": "^1.3.6",
    "chalk": "^4.1.2",
    "chokidar": "^4.0.3",
    "commander": "^11.0.0",
    "config-file-ts": "^0.2.8-rc1",
    "cross-spawn": "^7.0.3",
    "debug": "^4.4.0",
    "esbuild": "^0.21.5",
    "fs-extra": "^10.0.0",
    "globby": "^10.0.0",
    "is-type-of": "^1.2.1",
    "javascript-obfuscator": "^4.0.2",
    "json5": "^2.2.3",
    "mkdirp": "^2.1.3",
    "js-yaml": "^4.1.0",
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/cross-spawn": "^6.0.6",
    "@types/debug": "^4.1.12",
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/json5": "^2.2.0",
    "@types/mkdirp": "^2.0.0",
    "@types/node": "^20.16.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.7.2",
    "vitest": "^1.6.0"
  }
}
