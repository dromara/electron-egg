{
  // VS Code 任务配置版本
  "version": "2.0.0",
  "tasks": [
    {
      // 任务名称，被 launch.json 的 preLaunchTask 引用
      "label": "ee-build-dev",

      // 任务类型：shell = 在终端中执行命令
      "type": "shell",

      // 执行的命令和参数
      // 等同于运行: pnpm exec ee-bin build --cmds=electron --env=dev
      // --cmds=electron  只构建 electron 主进程
      // --env=dev        设置 NODE_ENV=dev，启用 inline sourcemap 以支持断点调试
      "command": "pnpm",
      "args": ["exec", "ee-bin", "build", "--cmds=electron", "--env=dev"],

      // 归类为构建任务，可通过 Ctrl+Shift+B 快捷运行
      "group": "build",

      // 不使用问题匹配器（构建输出不是标准错误格式）
      "problemMatcher": []
    }
  ]
}
