{
  "name": "ee-next",
  "version": "5.0.0",
  "description": "A fast, desktop software development framework",
  "main": "./public/electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "ee-bin-ts dev",
    "build": "pnpm run build-frontend && pnpm run build-electron && ee-bin-ts encrypt",
    "start": "ee-bin-ts start",
    "dev-frontend": "ee-bin-ts dev --serve=frontend",
    "dev-electron": "ee-bin-ts dev --serve=electron",
    "dev-go": "ee-bin-ts exec --cmds=go",
    "dev-go-w": "ee-bin-ts exec --cmds=go_w",
    "dev-python": "ee-bin-ts exec --cmds=python",
    "build-frontend": "ee-bin-ts build --cmds=frontend && ee-bin-ts move --flag=frontend_dist",
    "build-electron": "ee-bin-ts build --cmds=electron",
    "build-go-w": "ee-bin-ts move --flag=go_static,go_config,go_package && ee-bin-ts build --cmds=go_w",
    "build-go-m": "ee-bin-ts move --flag=go_static,go_config,go_package,go_images && ee-bin-ts build --cmds=go_m",
    "build-go-l": "ee-bin-ts move --flag=go_static,go_config,go_package,go_images && ee-bin-ts build --cmds=go_l",
    "build-python": "ee-bin-ts build --cmds=python && ee-bin-ts move --flag=python_dist",
    "encrypt": "ee-bin-ts encrypt",
    "icon": "ee-bin-ts icon",
    "build-w": "ee-bin-ts build --cmds=win64",
    "build-we": "ee-bin-ts build --cmds=win_e",
    "build-m": "ee-bin-ts build --cmds=mac",
    "build-m-arm64": "ee-bin-ts build --cmds=mac_arm64",
    "build-l": "ee-bin-ts build --cmds=linux",
    "debug-dev": "cross-env DEBUG=ee-* ee-bin-ts dev",
    "debug-encrypt": "ee-bin-ts encrypt",
    "debug-electron": "cross-env DEBUG=ee-* ee-bin-ts dev --serve=electron",
    "debug-move": "ee-bin-ts move --flag=frontend_dist",
    "re-sqlite": "electron-rebuild -f -w better-sqlite3"
  },
  "repository": "https://github.com/dromara/electron-egg.git",
  "keywords": [
    "Electron",
    "electron-egg",
    "ElectronEgg"
  ],
  "author": "哆啦好梦, Inc <530353222@qq.com>",
  "license": "Apache",
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.19.1",
    "cross-env": "^7.0.3",
    "debug": "^4.4.0",
    "ee-bin-ts": "workspace:*",
    "electron": "^39.8.10",
    "electron-builder": "^26.3.5"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "better-sqlite3": "^12.5.0",
    "dayjs": "^1.11.13",
    "ee-core-ts": "workspace:*",
    "electron-updater": "^6.7.3"
  }
}
